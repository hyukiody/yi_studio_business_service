# Security: Do not inject real values into this file.
# Environment variables are resolved strictly at runtime.

# Immutable Privacy Constraints: Environment Variable Isolation
# All secrets must be injected by the Edge provider's secure execution context.

# ========================================
# PUBLIC VARIABLES (safe to commit)
# ========================================
NEXT_PUBLIC_TURNSTILE_SITE_KEY=string
NEXT_PUBLIC_APP_URL=string
NEXT_PUBLIC_SITE_URL=string
NEXT_PUBLIC_API_VERSION=v1

# ========================================
# DATABASE (Prisma + PostgreSQL/SQLite)
# ========================================
# PostgreSQL: postgresql://user:password@localhost:5432/yi_studio?schema=public
# SQLite: file:./dev.db
DATABASE_URL=string

# ========================================
# SECURITY & CAPTCHA
# ========================================
TURNSTILE_SECRET_KEY=string
SECURE_WHATSAPP_NUMBER=string_numeric
WHATSAPP_API_TOKEN=string

# ========================================
# RATE LIMITING (Upstash Redis)
# ========================================
UPSTASH_REDIS_URL=string
UPSTASH_REDIS_TOKEN=string

# ========================================
# TELEMETRY & ANALYTICS
# ========================================
TELEMETRY_PROVIDER=string
NEXT_PUBLIC_SENTRY_DSN=string
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=string

# ========================================
# APPLICATION ENVIRONMENT
# ========================================
NODE_ENV=development
